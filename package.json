{
  "name": "@front-utils/linter",
  "version": "1.4.0",
  "description": "Configuration files for linting",
  "author": "IVGolubev",
  "license": "ISC",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/front-util/linter.git"
  },
  "types": "./types/index.d.ts",
  "exports": {
    "./types/*": "./types/*",
    "./dist/*": {
      "import": "./dist/*",
      "types": "./types/*"
    },
    ".": {
      "import": "./dist/index.js",
      "types": "./types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "types"
  ],
  "scripts": {
    "check:lint": "eslint --max-warnings=0 --fix --cache --config ./eslint.config.ts",
    "check:types": "tsc --noEmit",
    "test": "bun test",
    "publish:linter": "bun run build && npm publish --access public",
    "build": "rm -rf dist && rm -rf types && tsc -p tsconfig.build.json",
    "test:js": "cd test_pkg && eslint --max-warnings=0 --fix --cache --config ./eslint.config.js",
    "test:ts": "cd test_pkg && eslint --max-warnings=0 --fix --cache --config ./eslint.config.ts",
    "test:react": "cd test_pkg && eslint --max-warnings=0 --fix --cache --config ./eslint.config.react.js"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged --no-stash",
    "pre-push": "bun run test",
    "preserveUnused": true
  },
  "publishConfig": {
    "access": "public",
    "ignore": [
      ".github/",
      "tsconfig.json"
    ]
  },
  "keywords": [
    "ESLint",
    "ESLint-custom-config",
    "Eslint flat configuration",
    "ESLint-plugin"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.14",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/eslint__js": "^9.14.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun": "^1.3.14",
    "caniuse-lite": "^1.0.30001792",
    "eslint": "^10.3.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-filenames": "1.3.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-optimize-regex": "^1.2.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^16.3.0",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "typescript-eslint": ">=8.59.3"
  },
  "peerDependencies": {
    "@eslint/js": ">=9.0.0 || >=10.0.0",
    "@stylistic/eslint-plugin": "*",
    "eslint": ">=9.0.0 || >=10.0.0",
    "eslint-import-resolver-alias": "*",
    "eslint-import-resolver-typescript": "*",
    "eslint-plugin-compat": "*",
    "eslint-plugin-filenames": "*",
    "eslint-plugin-import": "*",
    "eslint-plugin-jsx-a11y": "*",
    "eslint-plugin-optimize-regex": "*",
    "eslint-plugin-promise": "*",
    "eslint-plugin-security": "*",
    "eslint-plugin-sonarjs": "*",
    "typescript-eslint": "*"
  },
  "peerDependenciesMeta": {
    "typescript-eslint": {
      "optional": true
    },
    "eslint-import-resolver-typescript": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "eslint-plugin-jest-dom": "*",
    "eslint-plugin-react": "*",
    "eslint-plugin-react-hooks": "*",
    "eslint-plugin-testing-library": "*",
    "globals": "*",
    "typescript-eslint": "*"
  }
}