{
  "name": "@front-utils/linter",
  "version": "2.1.1",
  "description": "Configuration files for linting",
  "author": "IVGolubev",
  "license": "ISC",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/front-util/linter.git"
  },
  "types": "./types/index.d.ts",
  "exports": {
    "./types/*": "./types/*",
    "./dist/*": {
      "import": "./dist/*",
      "types": "./types/*"
    },
    ".": {
      "import": "./dist/index.js",
      "types": "./types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "types"
  ],
  "scripts": {
    "check:lint": "eslint --max-warnings=0 --fix --cache --config ./eslint.config.ts",
    "check:types": "tsc --noEmit",
    "test": "bun test",
    "publish:linter": "bun run build && npm publish --access public",
    "build": "rm -rf dist && rm -rf types && tsc -p tsconfig.build.json",
    "test:js": "cd test_pkg && eslint --max-warnings=0 --fix --cache --config ./eslint.config.js",
    "test:ts": "cd test_pkg && eslint --max-warnings=0 --fix --cache --config ./eslint.config.ts",
    "test:react": "cd test_pkg && eslint --max-warnings=0 --fix --cache --config ./eslint.config.react.js",
    "test:css": "cd test_pkg && eslint --max-warnings=0 --fix --cache --config ./eslint.config.css.js"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged --no-stash",
    "pre-push": "bun run check:types && bun run test",
    "preserveUnused": true
  },
  "publishConfig": {
    "access": "public",
    "ignore": [
      ".github/",
      "tsconfig.json"
    ]
  },
  "keywords": [
    "ESLint",
    "ESLint-custom-config",
    "Eslint flat configuration",
    "ESLint-plugin"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.14",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun": "^1.3.14",
    "caniuse-lite": "^1.0.30001792",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-x": "^5.11.2",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^70.0.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "simple-git-hooks": "^2.13.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "*"
  },
  "peerDependencies": {
    "@eslint/css": ">=1.4.0",
    "@eslint/js": ">=10.0.0",
    "@stylistic/eslint-plugin": "*",
    "eslint": ">=10.4.0",
    "eslint-import-resolver-alias": "*",
    "eslint-import-resolver-typescript": "*",
    "eslint-plugin-check-file": "*",
    "eslint-plugin-compat": "*",
    "eslint-plugin-import-x": "*",
    "eslint-plugin-jsx-a11y": "*",
    "eslint-plugin-perfectionist": "*",
    "eslint-plugin-promise": "*",
    "eslint-plugin-security": "*",
    "eslint-plugin-sonarjs": "*",
    "eslint-plugin-unicorn": ">=70.0.0",
    "globals": "*",
    "typescript": ">=5.0.0 <7.0.0",
    "typescript-eslint": "*"
  },
  "peerDependenciesMeta": {
    "eslint-import-resolver-alias": {
      "optional": true
    },
    "eslint-import-resolver-typescript": {
      "optional": true
    },
    "eslint-plugin-react-x": {
      "optional": true
    },
    "globals": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "typescript-eslint": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "eslint-plugin-react-x": "*",
    "globals": "*",
    "typescript-eslint": "*"
  }
}